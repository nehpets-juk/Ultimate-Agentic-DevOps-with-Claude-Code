# Terraform state — never commit, contains sensitive AWS identifiers
terraform/*.tfstate
terraform/*.tfstate.*
terraform/.terraform/
terraform/.terraform.lock.hcl

# Local Terraform variable overrides
terraform/*.tfvars
terraform/*.tfvars.json

# Partial backend config — contains sensitive values (bucket name, region)
terraform/backend.hcl

# Claude local settings (contains AWS credentials/region)
.claude/settings.local.json
